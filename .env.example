ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
PRIVATE_KEY=
ARCSCAN_API_KEY=

# IPFS Storage (Pinata)
# Get JWT from: https://app.pinata.cloud/developers/api-keys
NFT_STORAGE_API_KEY=your_pinata_jwt_here

NEXT_PUBLIC_ARC_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_CHAIN_ID=5042002
NEXT_PUBLIC_CONTRACT_ADDRESS=
NEXT_PUBLIC_EXPLORER_URL=https://testnet.arcscan.app
NEXT_PUBLIC_EVENT_START_BLOCK=46313342

# USDC contract on Arc Testnet
# Get from: https://docs.arc.io/arc/references/contract-addresses
NEXT_PUBLIC_USDC_ADDRESS=

# NGO Sponsorship codes (comma separated, uppercase)
# Example: RSF2024,AMNESTY2024,CPJ2024
NEXT_PUBLIC_SPONSOR_CODES=

# Server-side auto-trigger bot for Vercel Cron / keeper.
# Use a dedicated funded Arc Testnet wallet, never your deployer/user key.
TRIGGER_BOT_PRIVATE_KEY=
CRON_SECRET=
AUTO_TRIGGER_MAX_TX=3
AUTO_TRIGGER_MAX_CHUNKS=120
AUTO_TRIGGER_BLOCK_CHUNK_SIZE=9000
